#!/bin/sh

echo "🐶 Husky vérifie la qualité et le style..."

# --- 1. QUALITÉ FRONT (ESLint) ---
docker compose run --rm quality eslint front/src --fix || exit 1

# --- 2. STYLE FRONT (Prettier) ---
docker compose run --rm quality npx prettier --write front/src --log-level warn

# --- 3. STYLE BACK (PHP-CS-Fixer) ---
# On utilise le conteneur "back" (PHP) car il possède déjà PHP et les dépendances
docker compose exec -T back vendor/bin/php-cs-fixer fix src --diff --ansi

# --- 4. VÉRIFICATION FINALE ---
git diff --exit-code > /dev/null
if [ $? -ne 0 ]; then
    echo "⚠️ Le code a été formaté automatiquement (PHP ou React)."
    echo "👉 Fais un 'git add .' et recommence ton commit."
    exit 1
fi

echo "✅ Qualité et Style validés !"